/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.local
.env.*.local

# OS files
Thumbs.db
.DS_Store
*.log

# Local environment
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build output
dist/
build/
.next/
out/

# Cache and temporary files
.cache/
.eslintcache
*.cache
tmp/
temp/

# IDE specific
.vscode/settings.json
.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace

# Node modules lockfiles (optional - uncomment if not committing)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Data files
data.json

# Markdown files (except README)
*.md
!README.md
